# Modelo de variáveis de ambiente. Copie para `.env` (local) ou configure na
# Vercel. NÃO coloque valores reais aqui — só placeholders.

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=COLOQUE_SUA_URL_DO_SUPABASE
SUPABASE_SERVICE_KEY=COLOQUE_SUA_SERVICE_ROLE_KEY

# ── Stripe (assinatura) ───────────────────────────────────────
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=COLOQUE_SUA_SECRET_KEY_DO_STRIPE
STRIPE_WEBHOOK_SECRET=COLOQUE_SEU_WEBHOOK_SECRET
# Crie os preços em: https://dashboard.stripe.com/products
STRIPE_PRICE_MENSAL=COLOQUE_O_PRICE_ID_MENSAL   # R$ 24,90/mês
STRIPE_PRICE_ANUAL=COLOQUE_O_PRICE_ID_ANUAL     # R$ 199/ano
# Quantos dias de trial gratuito
TRIAL_DAYS=7

# ── Web Push (VAPID) ──────────────────────────────────────────
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=COLOQUE_SUA_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=COLOQUE_SUA_VAPID_PRIVATE_KEY
VAPID_EMAIL=mailto:contato@sobasasas.com.br

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=COLOQUE_SUA_RESEND_API_KEY
EMAIL_FROM=anjos@sobasasas.com.br

# ── Admin (curadoria do Milagre do mês) ───────────────────────
ADMIN_KEY=defina_uma_chave_admin_forte

# ── reCAPTCHA ─────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=COLOQUE_SEU_RECAPTCHA_SECRET

# ── App ───────────────────────────────────────────────────────
APP_URL=https://sobasasas.com.br
